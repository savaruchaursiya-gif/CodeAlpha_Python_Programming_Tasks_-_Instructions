import tkinter as tk
import random

# words
word_list = ["apple", "tiger", "chair", "robot", "plant"]
word = random.choice(word_list)

display = []
for i in word:
    display.append("_")

used = []
lives = 6

# window
win = tk.Tk()
win.title("Hangman")
win.geometry("500x500")

# labels
word_label = tk.Label(win, text=" ".join(display), font=("Arial", 20))
word_label.pack(pady=20)

life_label = tk.Label(win, text="Lives: " + "♥"*lives)
life_label.pack()

msg = tk.Label(win, text="")
msg.pack(pady=10)

# update function
def update():
    word_label.config(text=" ".join(display))
    life_label.config(text="Lives: " + "♥"*(lives))

# check win/lose
def check():
    if "_" not in display:
        msg.config(text="You Win")
        for b in btns:
            b.config(state="disabled")
    if lives == 0:
        msg.config(text="You Lose, word was " + word)
        for b in btns:
            b.config(state="disabled")

# when button clicked
def click(l):
    global lives

    if l in used:
        msg.config(text="already used")
        return

    used.append(l)

    if l in word:
        msg.config(text="correct")
        for i in range(len(word)):
            if word[i] == l:
                display[i] = l
    else:
        msg.config(text="wrong")
        lives -= 1

    update()
    check()

# buttons A-Z
frame = tk.Frame(win)
frame.pack()

btns = []
letters = "abcdefghijklmnopqrstuvwxyz"

r = 0
c = 0

for l in letters:
    b = tk.Button(frame, text=l.upper(), width=5,
                  command=lambda x=l: click(x))
    b.grid(row=r, column=c, padx=2, pady=2)
    btns.append(b)

    c += 1
    if c == 7:
        c = 0
        r += 1

# full word guess
def guess_word():
    global lives
    g = entry.get()

    if g == word:
        for i in range(len(word)):
            display[i] = word[i]
        msg.config(text="correct word")
    else:
        lives -= 1
        msg.config(text="wrong word")

    entry.delete(0, tk.END)
    update()
    check()

entry = tk.Entry(win)
entry.pack(pady=10)

btn_guess = tk.Button(win, text="Guess Word", command=guess_word)
btn_guess.pack()

win.mainloop()
